                    className="liquid-glass rounded-full px-4 py-2 text-xs text-white/90 hover:scale-105 transition-transform cursor-default"
                  >
                    {skill}
                  </span>
                ))}
              </div>
            </div>

            {/* Chi tiết năng lực */}
            <div className="liquid-glass rounded-3xl p-6 space-y-4">
              <h3 className="text-sm font-semibold uppercase tracking-wider text-white/60">Mô tả năng lực thực thi</h3>
